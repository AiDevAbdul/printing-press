generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model challans {
  id                   String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  challan_number       String     @unique @db.VarChar(50)
  delivery_id          String     @db.Uuid
  challan_date         DateTime   @db.Date
  terms_and_conditions String?
  notes                String?
  generated_by_id      String     @db.Uuid
  created_at           DateTime   @default(now()) @db.Timestamp(6)
  company_id           String     @db.Uuid
  companies            companies  @relation(fields: [company_id], references: [id], onUpdate: NoAction, map: "FK_challans_company_id")
  deliveries           deliveries @relation(fields: [delivery_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_challan_delivery")
  users                users      @relation(fields: [generated_by_id], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_challan_generated_by")

  @@index([company_id], map: "IDX_challans_company_id")
  @@index([delivery_id], map: "idx_challan_delivery")
}

model companies {
  id                       String                     @id(map: "PK_companies") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                     String                     @unique @db.VarChar
  email                    String?                    @db.VarChar
  phone                    String?                    @db.VarChar
  address                  String?
  city                     String?                    @db.VarChar
  state                    String?                    @db.VarChar
  postal_code              String?                    @db.VarChar
  gstin                    String?                    @db.VarChar
  created_at               DateTime                   @default(now()) @db.Timestamp(6)
  updated_at               DateTime                   @default(now()) @db.Timestamp(6)
  challans                 challans[]
  customer_complaints      customer_complaints[]
  customers                customers[]
  deliveries               deliveries[]
  delivery_tracking        delivery_tracking[]
  design_approvals         design_approvals[]
  design_attachments       design_attachments[]
  designs                  designs[]
  inventory_items          inventory_items[]
  invoice_items            invoice_items[]
  invoices                 invoices[]
  job_costs                job_costs[]
  machine_counters         machine_counters[]
  material_consumption     material_consumption[]
  orders                   orders[]
  packing_lists            packing_lists[]
  payments                 payments[]
  product_specifications   product_specifications[]
  production_jobs          production_jobs[]
  production_stage_history production_stage_history[]
  quality_checkpoints      quality_checkpoints[]
  quality_defects          quality_defects[]
  quality_inspections      quality_inspections[]
  quality_rejections       quality_rejections[]
  quotation_history        quotation_history[]
  quotation_items          quotation_items[]
  quotations               quotations[]
  specification_approvals  specification_approvals[]
  stock_transactions       stock_transactions[]
  users                    users[]
  wastage_records          wastage_records[]

  @@index([name], map: "IDX_company_name")
}

model costing_config {
  id                        String   @id(map: "PK_6cea5c48782b56fe94472ce5eeb") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  paper_rate_per_kg         Decimal  @default(150) @db.Decimal(10, 2)
  gsm_rate_factor           Decimal  @default(0.0001) @db.Decimal(10, 6)
  cmyk_base_rate            Decimal  @default(2000) @db.Decimal(10, 2)
  special_color_rate        Decimal  @default(800) @db.Decimal(10, 2)
  spot_uv_rate_per_sqm      Decimal  @default(50) @db.Decimal(10, 2)
  lamination_rate_per_sqm   Decimal  @default(30) @db.Decimal(10, 2)
  embossing_rate_per_job    Decimal  @default(1500) @db.Decimal(10, 2)
  die_cutting_rate_per_1000 Decimal  @default(500) @db.Decimal(10, 2)
  pre_press_simple          Decimal  @default(2000) @db.Decimal(10, 2)
  pre_press_medium          Decimal  @default(3500) @db.Decimal(10, 2)
  pre_press_complex         Decimal  @default(5000) @db.Decimal(10, 2)
  pre_press_rush            Decimal  @default(8000) @db.Decimal(10, 2)
  is_active                 Boolean  @default(true)
  updated_at                DateTime @default(now()) @db.Timestamp(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model customer_complaints {
  id                                              String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  complaint_number                                String           @unique @db.VarChar(50)
  customer_id                                     String           @db.Uuid
  job_id                                          String?          @db.Uuid
  subject                                         String           @db.VarChar(200)
  description                                     String
  status                                          String           @default("open") @db.VarChar(20)
  severity                                        String           @default("medium") @db.VarChar(20)
  photo_url                                       String?          @db.VarChar(255)
  root_cause_analysis                             String?
  corrective_action                               String?
  preventive_action                               String?
  resolution_notes                                String?
  resolved_at                                     DateTime?        @db.Timestamp(6)
  assigned_to_id                                  String?          @db.Uuid
  created_by_id                                   String           @db.Uuid
  created_at                                      DateTime         @default(now()) @db.Timestamp(6)
  updated_at                                      DateTime         @default(now()) @db.Timestamp(6)
  company_id                                      String           @db.Uuid
  companies                                       companies        @relation(fields: [company_id], references: [id], onUpdate: NoAction, map: "FK_customer_complaints_company_id")
  users_customer_complaints_assigned_to_idTousers users?           @relation("customer_complaints_assigned_to_idTousers", fields: [assigned_to_id], references: [id], onUpdate: NoAction, map: "fk_complaint_assigned_to")
  users_customer_complaints_created_by_idTousers  users            @relation("customer_complaints_created_by_idTousers", fields: [created_by_id], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_complaint_created_by")
  customers                                       customers        @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_complaint_customer")
  production_jobs                                 production_jobs? @relation(fields: [job_id], references: [id], onUpdate: NoAction, map: "fk_complaint_job")

  @@index([company_id], map: "IDX_customer_complaints_company_id")
  @@index([customer_id], map: "idx_complaint_customer")
  @@index([severity], map: "idx_complaint_severity")
  @@index([status], map: "idx_complaint_status")
}

model customers {
  id                  String                @id(map: "PK_customers") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                String                @db.VarChar
  company_name        String?               @db.VarChar
  email               String                @db.VarChar
  phone               String                @db.VarChar
  address             String?
  city                String?               @db.VarChar
  state               String?               @db.VarChar
  postal_code         String?               @db.VarChar
  credit_limit        Decimal               @default(0) @db.Decimal(10, 2)
  credit_days         Int                   @default(30)
  payment_terms       String?
  is_active           Boolean               @default(true)
  created_by          String?               @db.Uuid
  created_at          DateTime              @default(now()) @db.Timestamp(6)
  updated_at          DateTime              @default(now()) @db.Timestamp(6)
  company_id          String                @db.Uuid
  customer_group      String?               @db.VarChar
  customer_type       String?               @db.VarChar
  folder_name         String?               @db.VarChar
  strn                String?               @db.VarChar
  ntn                 String?               @db.VarChar
  customer_complaints customer_complaints[]
  users               users?                @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_8f138f284609b045dc64c91757a")
  companies           companies             @relation(fields: [company_id], references: [id], onUpdate: NoAction, map: "FK_customers_company_id")
  deliveries          deliveries[]
  invoices            invoices[]
  orders              orders[]
  quotations          quotations[]

  @@index([company_id], map: "IDX_customers_company_id")
  @@index([company_id, is_active], map: "IDX_customers_company_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model deliveries {
  id                      String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  delivery_number         String              @unique @db.VarChar(50)
  job_id                  String              @db.Uuid
  customer_id             String              @db.Uuid
  delivery_status         String              @default("pending") @db.VarChar(20)
  delivery_type           String              @db.VarChar(20)
  scheduled_date          DateTime            @db.Date
  packed_at               DateTime?           @db.Timestamp(6)
  dispatched_at           DateTime?           @db.Timestamp(6)
  delivered_at            DateTime?           @db.Timestamp(6)
  courier_name            String?             @db.VarChar(100)
  tracking_number         String?             @db.VarChar(100)
  vehicle_number          String?             @db.VarChar(50)
  driver_name             String?             @db.VarChar(100)
  driver_phone            String?             @db.VarChar(20)
  delivery_address        String
  delivery_contact_name   String?             @db.VarChar(100)
  delivery_contact_phone  String?             @db.VarChar(20)
  pod_photo_url           String?             @db.VarChar(255)
  pod_signature_url       String?             @db.VarChar(255)
  received_by_name        String?             @db.VarChar(100)
  received_by_designation String?             @db.VarChar(100)
  delivery_notes          String?
  failure_reason          String?
  created_by_id           String              @db.Uuid
  created_at              DateTime            @default(now()) @db.Timestamp(6)
  updated_at              DateTime            @default(now()) @db.Timestamp(6)
  company_id              String              @db.Uuid
  challans                challans[]
  companies               companies           @relation(fields: [company_id], references: [id], onUpdate: NoAction, map: "FK_deliveries_company_id")
  users                   users               @relation(fields: [created_by_id], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_delivery_created_by")
  customers               customers           @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_delivery_customer")
  production_jobs         production_jobs     @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_delivery_job")
  delivery_tracking       delivery_tracking[]
  packing_lists           packing_lists[]

  @@index([company_id], map: "IDX_deliveries_company_id")
  @@index([customer_id], map: "idx_delivery_customer")
  @@index([job_id], map: "idx_delivery_job")
  @@index([scheduled_date], map: "idx_delivery_scheduled_date")
  @@index([delivery_status], map: "idx_delivery_status")
}

model delivery_tracking {
  id            String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  delivery_id   String     @db.Uuid
  status        String     @db.VarChar(100)
  location      String?    @db.VarChar(200)
  notes         String?
  updated_by_id String     @db.Uuid
  created_at    DateTime   @default(now()) @db.Timestamp(6)
  company_id    String     @db.Uuid
  companies     companies  @relation(fields: [company_id], references: [id], onUpdate: NoAction, map: "FK_delivery_tracking_company_id")
  deliveries    deliveries @relation(fields: [delivery_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tracking_delivery")
  users         users      @relation(fields: [updated_by_id], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_tracking_updated_by")

  @@index([company_id], map: "IDX_delivery_tracking_company_id")
  @@index([delivery_id], map: "idx_tracking_delivery")
}

